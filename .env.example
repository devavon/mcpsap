# ============================================================
#  MCP SAP Business One — Variables de entorno
#  Copia este archivo a ".env" y completa los valores reales.
#  En Railway, define estas variables en el panel (no subas .env).
# ============================================================

# --- SAP Service Layer (cuenta de servicio única) ---
# URL base del Service Layer, normalmente termina en /b1s/v1
# (puede sobreescribirse por empresa en config/companies.json)
SAP_SL_URL=https://TU_SERVIDOR:50000/b1s/v1
# CompanyDB por defecto — OPCIONAL.
#   - Multiempresa: deje vacío y defina las empresas en config/companies.json
#   - Monoempresa rápido: ponga aquí la CompanyDB y omita companies.json
SAP_COMPANY_DB=
# Usuario y clave de la CUENTA DE SERVICIO de SAP B1
# (debe existir y tener acceso en CADA empresa/CompanyDB configurada)
SAP_USERNAME=mcp_service
SAP_PASSWORD=cambia_esto
# Verificar certificado TLS del Service Layer.
#   - "true"  => exige certificado válido
#   - "false" => acepta autofirmado (común en SAP con IP/host interno)
SAP_TLS_REJECT_UNAUTHORIZED=false

# --- Servidor MCP (HTTP/SSE central) ---
MCP_HOST=0.0.0.0
# Puerto local. En Railway/Heroku se ignora: la plataforma inyecta PORT.
MCP_PORT=3000
# Ruta donde el servidor MCP escucha (StreamableHTTP)
MCP_PATH=/mcp

# --- Seguridad / sesiones del MCP ---
# Minutos de inactividad antes de cerrar la sesión de un usuario del MCP
MCP_SESSION_TTL_MIN=60
# Minutos de vida de una acción pendiente de confirmación antes de expirar
MCP_PENDING_TTL_MIN=10
# API key para proteger el endpoint MCP (RECOMENDADA al exponer públicamente).
# Si se define, el cliente debe enviar 'x-api-key: <valor>' o 'Authorization: Bearer <valor>'.
MCP_API_KEY=

# --- Archivos de configuración (modo local) ---
ROLES_FILE=./config/roles.json
USERS_FILE=./config/users.json
COMPANIES_FILE=./config/companies.json

# --- Config por variables de entorno (modo nube / Railway) ---
# Si se definen, tienen prioridad sobre los archivos anteriores. Útiles cuando
# el archivo no se sube (users.json está en .gitignore). Contienen el JSON completo.
# USERS_JSON={"users":[...]}
# COMPANIES_JSON={"companies":{...}}
# ROLES_JSON={"roles":{...}}

# --- Auditoría ---
# Carpeta de logs (en Railway el disco es efímero: se pierde al redeploy)
AUDIT_DIR=./audit-logs
# Loguear también a stdout (recomendado en Railway para capturar en sus logs)
AUDIT_STDOUT=false
